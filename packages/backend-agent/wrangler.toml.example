name = "verato-agent"
main = "src/index.ts"
compatibility_date = "2024-12-01"
compatibility_flags = ["nodejs_compat"]

[vars]
VERATO_ADDRESS = "0x8bDed3d811501273Fe60da50fbA91FD0bC25B9F1"
FORWARDER_ADDRESS = "0x54b3c0aeB93b3A00675cb7bcC88ee9B0a25a4223"
CHAIN_ID = "42220"
RPC_URL = "https://forno.celo.org"
ORDERS_API_URL = "https://verato-orders.<YOUR_SUBDOMAIN>.workers.dev"

# Secrets (set via `wrangler secret put`):
#   ANTHROPIC_API_KEY  — Claude API key for agent reasoning
#   OPENAI_API_KEY=
#   PRIVATE_KEY        — wallet private key for signing/submitting txs
