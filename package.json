{
  "name": "delta-synthesis",
  "private": true,
  "packageManager": "pnpm@10.16.1",
  "scripts": {
    "dev": "pnpm --filter @delta-synthesis/frontend dev",
    "build": "pnpm --filter @delta-synthesis/frontend build",
    "sdk:build": "pnpm --filter @delta-synthesis/settlement-sdk build",
    "sdk:dev": "pnpm --filter @delta-synthesis/settlement-sdk dev",
    "contracts:build": "pnpm --filter contracts build",
    "contracts:test": "pnpm --filter contracts test",
    "agent:dev": "pnpm --filter @delta-synthesis/backend-agent dev",
    "agent:deploy": "pnpm --filter @delta-synthesis/backend-agent deploy",
    "orders:dev": "pnpm --filter @delta-synthesis/backend-orders dev",
    "orders:deploy": "pnpm --filter @delta-synthesis/backend-orders deploy"
  }
}
